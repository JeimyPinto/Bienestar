{
  "name": "bienestar",
  "version": "1.0.0",
  "description": "Aplicación para ofertar los servicios de Bienestar al Aprendiz",
  "main": "app.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "node --watch app.js",
    "start": "node app.js",
    "build": "echo 'No build step required'",
    "migrate": "sequelize-cli db:migrate --config config/config.json --env production",
    "seed": "sequelize-cli db:seed:all --config config/config.json --env production",
    "migrate-seed": "npm run migrate && npm run seed",
    "undo:all": "sequelize-cli db:migrate:undo:all --config config/config.json --env production && sequelize-cli db:seed:undo:all --config config/config.json --env production",
    "migrate:dev": "dotenv -e .env -- sequelize-cli db:migrate --config config/config.json --env development",
    "seed:dev": "dotenv -e .env -- sequelize-cli db:seed:all --config config/config.json --env development",
    "migrate-seed:dev": "npm run migrate:dev && npm run seed:dev",
    "undo:all:dev": "dotenv -e .env -- sequelize-cli db:seed:undo:all --config config/config.json --env development && dotenv -e .env -- sequelize-cli db:migrate:undo:all --config config/config.json --env development && npm run clean:uploads:dev",
    "clean:uploads:dev": "node -e \"const fs=require('fs');const p=['./uploads/images/users','./uploads/images/services'];p.forEach(d=>{if(fs.existsSync(d))fs.readdirSync(d).forEach(f=>fs.rmSync(d+'/'+f,{recursive:true,force:true}))});\""
  },
  "keywords": [
    "bienestar",
    "sena",
    "api",
    "nodejs",
    "express"
  ],
  "author": "Jeimy Pinto",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^9.8.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.27.0",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.30.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^8.0.5",
    "pg": "^8.16.2",
    "pg-hstore": "^2.3.4",
    "rimraf": "^6.0.1",
    "sequelize": "^6.37.4",
    "sequelize-cli": "^6.6.3",
    "validator": "13.15.22",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.25.67"
  },
  "overrides": {
    "tar": "^7.5.9",
    "ajv": "^6.14.0",
    "minimatch": "^3.1.3 || ^9.0.6 || ^10.2.3"
  }
}